{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "timezone": "America/Denver",
  "pip-compile": {
    "managerFilePatterns": ["/(^|/)requirements.*\\.txt$/"]
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["python"],
      "matchUpdateTypes": ["digest"],
      "automerge": false
    }
  ]
}
