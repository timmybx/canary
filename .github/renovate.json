{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "timezone": "America/Denver",
  "pip-compile": {
    "managerFilePatterns": ["/(^|/)requirements-dev\\.txt$/"],
    "rangeStrategy": "bump"
  },
  "pip_requirements": {
    "enabled": false
  },
  "pre-commit": {
    "pinDigests": true
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["python"],
      "allowedVersions": "<3.13",
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "matchDepNames": ["python"],
      "allowedVersions": "<3.13"
    },
    {
      "description": "Throttle fuzzer Docker digest updates to weekly",
      "matchManagers": ["dockerfile"],
      "matchFileNames": [".clusterfuzzlite/Dockerfile"],
      "schedule": ["on monday"]
    }
  ]
}
